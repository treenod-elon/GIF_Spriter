# Gemini AI API key for auto title/tag/category detection
# Get yours at: https://aistudio.google.com/app/apikey
# Leave empty to use filename-based fallback
GEMINI_API_KEY=

# Processing limits (hardcoded in src/lib/utils/constants.ts)
# Documented here for reference — not read from env at runtime
# MAX_UPLOAD_SIZE_MB=100
# MAX_VIDEO_DURATION_SEC=10
# MAX_FRAMES=180
# SPRITESHEET_MAX_WIDTH=4096
# SPRITESHEET_MAX_HEIGHT=4096
